# ─────────────────────────────────────────────────────────────────
#  K12 Insights Platform — Frontend Environment Template
#  Copy to .env.local and fill in values. NEVER commit .env.local to git.
#
#  !! IMPORTANT: Never put database credentials, internal IPs, or any
#     server-side secrets in VITE_ variables. They are bundled into the
#     client JS and visible to every browser.
# ─────────────────────────────────────────────────────────────────

# Backend Express API base URL (no trailing slash)
# Dev:  http://localhost:5000
# Prod: https://api.your-domain.com
VITE_API_URL=http://localhost:5000

# App environment label  (development | staging | production)
VITE_APP_ENV=development

# Feature flags
# Set to false — this app connects to the real DASL MySQL database.
# Mock data mode has been removed.
VITE_ENABLE_MOCK_DATA=false
