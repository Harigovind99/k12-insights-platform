# ─────────────────────────────────────────────────────────────────
#  K12 Insights Platform — Backend Environment Variables
#  Copy to .env and fill in real values. Never commit this file.
# ─────────────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# CORS — must match the Vite dev server origin
CORS_ORIGIN=http://localhost:5173

# ── SQL Server / DASL (NTLM Windows Auth) ─────────────────────────
DB_SERVER=10.3.30.24
DB_PORT=1433
# Leave DB_INSTANCE blank unless using a named instance (e.g. SQLEXPRESS)
DB_INSTANCE=
# Domain prefix for NTLM — your login is dsl\<username>
DB_DOMAIN=dsl
# Your Windows username WITHOUT the domain prefix
DB_USER=harikumar
DB_PASSWORD=Samruddhiappumon@1404
# Leave blank — all queries are fully-qualified (no USE <db> needed)
DB_DATABASE=DASL
DB_POOL_MIN=2
DB_POOL_MAX=10
