# ─────────────────────────────────────────────────────────────────────────────
#  K12 Insights Platform  –  Backend Environment Variables
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────────────────────────────
# Must match the Vite dev server port (default 5173)
CORS_ORIGIN=http://localhost:5173

# ── DASL SQL Server (read-only) ───────────────────────────────────────────────
#
#  Connection uses Windows / NTLM domain authentication —
#  the same credentials you use to sign into SSMS.
#
#  Format in SSMS:  Server name  →  1.1.1.1,1433  (or  1.1.1.1\INSTANCE)
#
DB_SERVER=10.3.30.24
DB_PORT=1433

# Named instance (leave blank if none)
DB_INSTANCE=

# Database name (the DASL read-only database)
DB_NAME=DASL

# NTLM domain  (the part before \ in dsl\username)
DB_DOMAIN=dsl

# Windows username  (the part after \ — do NOT include the domain prefix here)
DB_USER=your_windows_username

# Windows account password
DB_PASSWORD=your_windows_password

# Connection pool
DB_POOL_MAX=10

# ── JWT ───────────────────────────────────────────────────────────────────────
#  Generate with:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_generated_secret
JWT_EXPIRES_IN=8h

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Security warning ─────────────────────────────────────────────────────────
#  This backend connects to a READ-ONLY database.
#  All queries are SELECT-only — no INSERT/UPDATE/DELETE are issued.
#  Do not expose this service publicly without a firewall or VPN.
